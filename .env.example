# Copy to .env and adjust:  cp .env.example .env
# Docker Compose loads .env automatically for ${VAR} substitution in docker-compose.yml.

# --- Published ports (host:container) ---
LAIGHTDB_HTTP_PORT=8080
LAIGHTDB_UI_PORT=3000
# Dev profile: laightdb-dev-mcp streamable HTTP (Cursor MCP url)
LAIGHTDB_DEV_MCP_PORT=9090

# --- LaightDB core (both match docker-compose defaults if omitted) ---
LAIGHTDB_MCP_TRANSPORT=http

# --- Summarizer when storing context: noop | openai | anthropic | ollama ---
LAIGHTDB_SUMMARIZER=noop

# OpenAI-compatible API (OpenAI cloud, LM Studio, vLLM, etc.)
# LAIGHTDB_OPENAI_API_KEY=
# LAIGHTDB_OPENAI_BASE_URL=https://api.openai.com/v1
# LAIGHTDB_OPENAI_MODEL=gpt-4o-mini

# LM Studio on your host while LaightDB runs in Docker (Linux: use host gateway IP or extra_hosts; macOS/Windows often work with host.docker.internal)
# LAIGHTDB_OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# LAIGHTDB_OPENAI_MODEL=your-loaded-model-id

# Anthropic
# LAIGHTDB_ANTHROPIC_API_KEY=

# Ollama on host (from inside Docker use host.docker.internal on Mac/Win, or 172.17.0.1 on Linux)
# LAIGHTDB_OLLAMA_URL=http://host.docker.internal:11434

# --- Authentication ---
# Seed an admin user on first start (format: username:password)
# LAIGHTDB_BOOTSTRAP_USER=admin:changeme

# Session cookie TTL (Go duration, default 24h)
# LAIGHTDB_SESSION_TTL=24h

# Rate limiting (per user or per IP)
# LAIGHTDB_RATE_LIMIT_RPS=100
# LAIGHTDB_RATE_LIMIT_BURST=200

# --- Dev MCP (laightdb-dev-mcp binary only) ---
# Streamable HTTP on this address; leave unset for stdio MCP. Prefer 127.0.0.1 in dev.
# LAIGHTDB_DEV_MCP_HTTP_ADDR=127.0.0.1:9090
# When the API already has the data dir open (e.g. Docker dev stack), avoid double-opening the DB:
# LAIGHTDB_DEV_MCP_SKIP_STORE=true

# --- Optional tuning ---
# LAIGHTDB_MEMTABLE_SIZE=4194304
# LAIGHTDB_SEARCH_TOP_K=10

# Browser CORS: Access-Control-Allow-Origin (empty = no CORS headers)
# LAIGHTDB_CORS_ORIGIN=https://localhost:3000

# Periodic on-disk snapshots for BM25/metadata/graph indexes (Go duration; 0 or empty = disabled)
# LAIGHTDB_SNAPSHOT_INTERVAL=5m
